FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0/beam";
    object      W;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    left
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    right
    {
        displacementSeries
        {
            file            "$FOAM_CASE/constant/beam/timeVsDisplacement";
            outOfBounds     clamp;
        }
        type            fixedValue;
        value           uniform (0 0 0);
    }
    beam
    {
        type            empty;
    }
}


