FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     beamFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1;

deltaT          0.001;//0.002;

writeControl    timeStep;

writeInterval   10;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression uncompressed;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

functions
{
   beamDisplacements0
   {
       type    beamDisplacements;
       historyPatch    right_0;
   }

   beamDisplacements1
   {
       type    beamDisplacements;
       historyPatch    right_1;
   }

   beamDisplacements2
   {
       type    beamDisplacements;
       historyPatch    right_2;
   }

   beamConvergenceData
   {
       type    beamConvergenceData;
   }

   beamForcesMoments0
   {
       type    beamForcesMoments;
       historyPatch    left_0;
   }

   beamForcesMoments1
   {
       type    beamForcesMoments;
       historyPatch    left_1;
   }

   beamForcesMoments2
   {
       type    beamForcesMoments;
       historyPatch    left_2;
   }

   beamEnergyData
   {
       type    beamEnergyData;
   }
}

