FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      beamProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

beamModel coupledTotalLagNewtonRaphsonBeam;

beams
(
    beam_0
    {
        crossSectionModel rectangle;

        rectangleCrossSectionModelDict
        {
            h 0.0004;
            b 0.025;
            nx 1;
            ny 1;
        }

        length 0.4;
        nSegments 80;
    }
);

"coupledTotalLagNewtonRaphsonBeamCoeffs"
{
    E E [1 -1 -2 0 0 0 0] 194.3e09;
    G G [1 -1 -2 0 0 0 0] 74.73e09; // steel bar, nu = 0.3
    rho rho [1 -3 0 0 0 0 0] 7730;
    //- convergence check parameters----------------
    nCorrectors 200;
    residualTol 1e-08;
    solutionTol 1e-08;
    absoluteTol 1e-08;
    convergenceTol 1e-08;
    divergenceTol    1e8;
}



