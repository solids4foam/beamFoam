FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      W;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    // Clamped edge
    left
    {
        type fixedValue;
        value uniform (0 0 0);
    }

    // Spring Boundary condition at right edge
    right
    {
        type linearSpringForceBeamDisplacementNR;

        linearSpringCoeffs
        {
            springStiffness 800;
            springDirection (0 1 0);
        }

    }
    
    beam
    {
        type empty;
    }
}


