FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      q;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 0 -2 0 0 0 0];

internalField   uniform (0 -1000 0);

boundaryField
{
    "right|left"
    {
        type            calculated;
        value           uniform (0 0 0);
    }

    beam
    {
         type            empty;
    }
}

